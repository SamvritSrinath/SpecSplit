# Copy this file to something like:
#   /home/youruser/specsplit-draft.env

ROLE=draft
WORKDIR=/home/andrew/ucsd/cse291p/SpecSplit
PYTHON_BIN=/home/andrew/ucsd/cse291p/SpecSplit/.venv/bin/python
STATE_DIR=/home/andrew/ucsd/cse291p/SpecSplit/.run/draft

# Keep this off only if you do not want to expose the worker publicly.
NGROK_ENABLE=1
NGROK_BIN=ngrok
# Optional override if your ngrok agent API is not on the default local address.
# NGROK_API_URL=http://127.0.0.1:4040/api

# Optional: set this if you reserved a fixed ngrok TCP address.
# If left unset, ngrok will assign a new public address on each restart.
# NGROK_TCP_URL=tcp://1.tcp.us-cal-1.ngrok.io:12345

GIT_REMOTE=origin
GIT_BRANCH=samvrit_arul_dev

# Set this to 1 only if a pull may change dependencies. Editable installs
# usually do not need a reinstall after a plain code pull.
REINSTALL_AFTER_PULL=0

SPECSPLIT_DRAFT_MODEL_NAME=~/models/Llama-3.1-8B/
SPECSPLIT_DRAFT_DEVICE=cuda:0
SPECSPLIT_DRAFT_GRPC_PORT=50051
SPECSPLIT_DRAFT_MAX_DRAFT_TOKENS=5
